<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#8D4E2A"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚚 Track Order"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <!-- Order Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_margin="12dp">

            <TextView
                android:id="@+id/txtTrackOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORD12345"
                android:textColor="#3E2723"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTrackOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#8D6E63"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦 Items:"
                android:textColor="#5D4037"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTrackItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items"
                android:textColor="#3E2723"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/txtTrackTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#C62828"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Tracking Timeline -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Order Status"
                android:textColor="#5D4037"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Step 1: Confirmed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/iconStep1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="✓"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#2E7D32"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStep1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Confirmed"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtStep1Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textColor="#8D6E63"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="30dp"
                android:background="#E0E0E0"
                android:layout_marginStart="19dp"/>

            <!-- Step 2: Packed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/iconStep2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="2"
                    android:textColor="#8D6E63"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#E0E0E0"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStep2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Packed"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtStep2Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="#8D6E63"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="30dp"
                android:background="#E0E0E0"
                android:layout_marginStart="19dp"/>

            <!-- Step 3: Shipped -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/iconStep3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="3"
                    android:textColor="#8D6E63"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#E0E0E0"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStep3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shipped"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtStep3Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="#8D6E63"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="30dp"
                android:background="#E0E0E0"
                android:layout_marginStart="19dp"/>

            <!-- Step 4: Out for Delivery -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/iconStep4"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="4"
                    android:textColor="#8D6E63"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#E0E0E0"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStep4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Out for Delivery"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtStep4Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="#8D6E63"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="30dp"
                android:background="#E0E0E0"
                android:layout_marginStart="19dp"/>

            <!-- Step 5: Delivered -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/iconStep5"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="5"
                    android:textColor="#8D6E63"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#E0E0E0"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtStep5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivered"
                        android:textColor="#3E2723"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtStep5Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expected"
                        android:textColor="#8D6E63"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Delivery Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Delivery Address"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTrackCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Name"
                android:textColor="#3E2723"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txtTrackPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textColor="#5D4037"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/txtTrackAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textColor="#5D4037"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btnCancelOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ CANCEL ORDER"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="#C62828"
            android:padding="14dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>

</ScrollView>