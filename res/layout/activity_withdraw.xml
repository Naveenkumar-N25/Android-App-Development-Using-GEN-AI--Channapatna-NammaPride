<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#5D4037"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💸 Withdraw Money"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <!-- Balance Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2E7D32"
            android:padding="20dp"
            android:gravity="center"
            android:layout_margin="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 AVAILABLE BALANCE"
                android:textColor="#C8E6C9"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtWithdrawBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Bank Info -->
        <LinearLayout
            android:id="@+id/layoutBankInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_margin="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🏦 Bank Account"
                    android:textColor="#5D4037"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btnEditBank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Edit"
                    android:textColor="#1976D2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <TextView
                android:id="@+id/txtBankName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Name"
                android:textColor="#3E2723"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtBankAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account"
                android:textColor="#5D4037"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/txtBankHolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Holder"
                android:textColor="#5D4037"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- No Bank Info -->
        <LinearLayout
            android:id="@+id/layoutNoBank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFCDD2"
            android:padding="20dp"
            android:gravity="center"
            android:layout_margin="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No bank details added"
                android:textColor="#B71C1C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnAddBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ ADD BANK DETAILS"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="#C62828"
                android:padding="12dp"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💰 Withdrawal Amount"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editWithdrawAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter amount (Min ₹100)"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:inputType="number"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <!-- Quick Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/btnAmount500"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="₹500"
                    android:textColor="#5D4037"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="#FFE0B2"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnAmount1000"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="₹1000"
                    android:textColor="#5D4037"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="#FFE0B2"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="6dp"/>

                <TextView
                    android:id="@+id/btnAmountAll"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="#2E7D32"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnConfirmWithdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💸 WITHDRAW NOW"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="#2E7D32"
                android:padding="16dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>