<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#5D4037"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🪪 Digital Profile"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎨"
            android:textSize="80sp"
            android:gravity="center"
            android:padding="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Full Name *"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editArtisanName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter your full name"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📧 Email"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editArtisanEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8D6E63"
                android:padding="14dp"
                android:background="#F5F5F5"
                android:enabled="false"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📞 Phone"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editArtisanPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter phone number"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:inputType="phone"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎯 Specialization"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editSpecialization"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Spinning Tops, Dolls, Animals"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅 Years of Experience"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editExperience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 25"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:inputType="number"
                android:layout_marginTop="6dp"/>

            <!-- GIS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E1F5FE"
                android:padding="14dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Workshop Location (GIS)"
                    android:textColor="#0D47A1"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="For mapping artisan workshops"
                    android:textColor="#1565C0"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

                <EditText
                    android:id="@+id/editWorkshopAddress"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="Workshop full address"
                    android:textColor="#3E2723"
                    android:textColorHint="#A1887F"
                    android:padding="14dp"
                    android:background="#FFFFFF"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🌐 Latitude"
                            android:textColor="#0D47A1"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <EditText
                            android:id="@+id/editLatitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="12.6516"
                            android:textColor="#3E2723"
                            android:textColorHint="#A1887F"
                            android:padding="10dp"
                            android:background="#FFFFFF"
                            android:inputType="numberDecimal"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🌐 Longitude"
                            android:textColor="#0D47A1"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <EditText
                            android:id="@+id/editLongitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="77.2058"
                            android:textColor="#3E2723"
                            android:textColorHint="#A1887F"
                            android:padding="10dp"
                            android:background="#FFFFFF"
                            android:inputType="numberDecimal"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnUseChannapatna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Use Channapatna Default"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#1976D2"
                    android:padding="10dp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📖 About Me"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/editArtisanBio"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Tell us about your craft, family heritage..."
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾 SAVE PROFILE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="#5D4037"
                android:padding="16dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>