<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#5D4037"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏦 Bank Details"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏦"
            android:textSize="60sp"
            android:gravity="center"
            android:padding="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add your bank details to receive payments"
            android:textColor="#5D4037"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏦 Bank Name *"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editBankName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. State Bank of India"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Account Holder Name *"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editHolderName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="As per bank account"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 Account Number *"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter account number"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:inputType="number"
                android:maxLength="20"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏛 IFSC Code *"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editIfsc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. SBIN0001234"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:maxLength="11"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📱 UPI ID (Optional)"
                android:textColor="#5D4037"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/editUpi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. yourname@upi"
                android:textColor="#3E2723"
                android:textColorHint="#A1887F"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnSaveBank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾 SAVE BANK DETAILS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="#2E7D32"
                android:padding="16dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>